{
  "name": "node-interface-demo",
  "productName": "Nodes Node Nodes",
  "version": "0.1.0",
  "main": "dist/electron/main.cjs",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n renderer,electron-build,electron \"vite\" \"tsup --config tsup.config.ts --watch\" \"wait-on tcp:5173 dist/electron/main.cjs dist/electron/preload.cjs dist/electron/worker.cjs && NODE_ENV=development ELECTRON_RENDERER_URL=http://localhost:5173 electronmon dist/electron/main.cjs\"",
    "test:unit": "node --import tsx --test src/lib/*.test.ts",
    "build": "vite build && tsup --config tsup.config.ts",
    "start": "NODE_ENV=production electron dist/electron/main.cjs",
    "smoke:electron": "npm run build && node --import tsx scripts/electron-smoke.ts",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "@tanstack/react-router": "^1.132.31",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.44.7",
    "electron": "^38.3.0",
    "openai": "^6.26.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "electronmon": "^2.0.2",
    "eslint": "^9",
    "playwright": "^1.58.2",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  }
}
